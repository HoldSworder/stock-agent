# ===== 服务（进程级基础设施配置）=====
PORT=8787
# SQLite 数据库文件路径（容器内挂载卷）
DATABASE_PATH=./data/stock-agent.sqlite
# 宿主数据目录（docker-compose 挂载到 /app/data）。
# 群晖部署填 Synology 共享文件夹绝对路径，如 /volume1/docker/stock-agent/data；
# 本地留空走默认 ./data。务必是 NAS 本地磁盘，切勿网络挂载（SQLite WAL 会损坏）。
DATA_DIR=./data
# 时区，所有定时任务默认时区
TZ=Asia/Shanghai

# 配套浏览器扩展推送凭据到 /api/credentials 时校验的共享密钥。
# 部署到公网时必须设置（否则该端点返回 503 禁用），扩展 popup 里填同一串。
BRIDGE_SECRET=
# 生产 CORS 白名单，逗号分隔（如 https://stock.example.com,chrome-extension://<扩展ID>）；
# 留空则反射任意来源，仅适合本地开发。
CORS_ORIGINS=

# 业务配置（模型 / 妙想 / Telegram / 同花顺持仓）一律存 SQLite，
# 请启动后在 WebUI「设置」页填写，无需写入本文件。
