# ===== 服务 =====
PORT=8787
# SQLite 数据库文件路径（容器内挂载卷）
DATABASE_PATH=./data/stock-agent.sqlite
# 时区，所有定时任务默认时区
TZ=Asia/Shanghai

# ===== 模型（任意 OpenAI 兼容服务）=====
# 也可启动后在 WebUI 设置页填写
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ===== 妙想（东方财富 AI SaaS）=====
# 新门户 key（em_ 前缀），用于 finance-data / screener / simulator
EM_API_KEY=
# 老门户 key（mkt_ 前缀），用于 self-select 等
MX_APIKEY=

# ===== Telegram 推送 =====
TELEGRAM_BOT_TOKEN=
# 默认推送的 chat id
TELEGRAM_CHAT_ID=
# 真实持仓话题 thread id（可选，对应原 openclaw thread 62）
TELEGRAM_THREAD_ID=

# ===== 真实持仓数据源（OpenViking）=====
# 复用 LXC portfolio-sync 写入 OpenViking 的同花顺持仓快照
# 快照 URI：<EVENTS_PREFIX>/YYYY/MM/DD/portfolio_snapshot.md
OPENVIKING_BASE_URL=http://192.168.31.144:9109
OPENVIKING_API_KEY=
OPENVIKING_ACCOUNT=user
OPENVIKING_USER=default
OPENVIKING_EVENTS_PREFIX=viking://user/default/memories/events
